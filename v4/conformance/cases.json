    "expect_lookup": [["5", null]]
  },
  {
    "name": "single",
    "family": "v4",
    "scope_width": 1,
    "ops": [{"op": "set", "from": "10", "to": "20", "scope": [1]}],
    "expect_scan": [["10", "20", [1]]],
    "expect_lookup": [["9", null], ["10", [1]], ["15", [1]], ["20", [1]], ["21", null]]
  },
  {
    "name": "split_middle",
    "family": "v4",
    "scope_width": 1,
    "ops": [
      {"op": "set", "from": "1", "to": "100", "scope": [1]},
      {"op": "set", "from": "40", "to": "50", "scope": [2]}
    ],
    "expect_scan": [["1", "39", [1]], ["40", "50", [2]], ["51", "100", [1]]],
    "expect_lookup": [["39", [1]], ["40", [2]], ["50", [2]], ["51", [1]]]
  },
  {
    "name": "coalesce_adjacent_same_scope",
    "family": "v4",
    "scope_width": 1,
    "ops": [
      {"op": "set", "from": "1", "to": "10", "scope": [7]},
      {"op": "set", "from": "11", "to": "20", "scope": [7]}
    ],
    "expect_scan": [["1", "20", [7]]],
    "expect_lookup": [["10", [7]], ["11", [7]]]
  },
  {
    "name": "no_coalesce_across_gap",
    "family": "v4",
    "scope_width": 1,
    "ops": [
      {"op": "set", "from": "1", "to": "10", "scope": [7]},
      {"op": "set", "from": "12", "to": "20", "scope": [7]}
    ],
    "expect_scan": [["1", "10", [7]], ["12", "20", [7]]],
    "expect_lookup": [["11", null]]
  },
  {
    "name": "no_coalesce_different_scope",
    "family": "v4",
    "scope_width": 1,
    "ops": [
      {"op": "set", "from": "1", "to": "10", "scope": [1]},
      {"op": "set", "from": "11", "to": "20", "scope": [2]}
    ],
    "expect_scan": [["1", "10", [1]], ["11", "20", [2]]],
    "expect_lookup": []
  },
  {
    "name": "overwrite_same_range",
    "family": "v4",
    "scope_width": 1,
    "ops": [
      {"op": "set", "from": "1", "to": "10", "scope": [1]},
      {"op": "set", "from": "1", "to": "10", "scope": [2]}
    ],
    "expect_scan": [["1", "10", [2]]],
    "expect_lookup": [["5", [2]]]
  },
  {
    "name": "delete_interior",
    "family": "v4",
    "scope_width": 1,
    "ops": [
      {"op": "set", "from": "1", "to": "100", "scope": [1]},
      {"op": "delete", "from": "40", "to": "50"}
    ],
    "expect_scan": [["1", "39", [1]], ["51", "100", [1]]],
    "expect_lookup": [["39", [1]], ["45", null], ["51", [1]]]
  },
  {
    "name": "delete_whole_tree",
    "family": "v4",
