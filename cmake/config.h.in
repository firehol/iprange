#cmakedefine HAVE_INTTYPES_H 1
#cmakedefine HAVE_STDINT_H 1

/* gcc branch optimization */
#ifdef __GNUC__
#define likely(x)   __builtin_expect(!!(x), 1)
#define unlikely(x) __builtin_expect(!!(x), 0)
#else
#define likely(x)   (x)
#define unlikely(x) (x)
#endif
